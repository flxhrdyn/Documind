# DocuMind AI - Environment Template
# Copy this file to .env and fill in required values.

# --- Required ---
# Google Gemini API key
GEMINI_API_KEY=

# --- Optional: Qdrant (recommended for deployments / multi-process) ---
# If QDRANT_URL is not set, the app falls back to local storage at qdrant_storage/.
# QDRANT_URL examples:
#   http://localhost:6333
#   https://<your-qdrant-cloud-host>
QDRANT_URL=
QDRANT_API_KEY=

# Prefer gRPC when using Qdrant server/cloud (0/1). Default is REST (0).
QDRANT_PREFER_GRPC=0

# --- Optional: Hybrid retrieval (best-practice RAG) ---
# Enable dense + lexical retrieval with weighted RRF fusion before reranking.
# 1 = enabled (default), 0 = force dense-only
DOCUMIND_ENABLE_HYBRID_SEARCH=1

# Number of lexical (BM25) candidates returned.
DOCUMIND_HYBRID_LEXICAL_K=10

# Max candidates kept after dense+lexical fusion.
DOCUMIND_HYBRID_FUSION_LIMIT=20

# Max number of chunks loaded into BM25 cache from Qdrant.
DOCUMIND_HYBRID_MAX_LEXICAL_DOCS=3000

# Weighted reciprocal rank fusion parameters.
DOCUMIND_HYBRID_RRF_K=60
DOCUMIND_HYBRID_DENSE_WEIGHT=1.0
DOCUMIND_HYBRID_LEXICAL_WEIGHT=1.0

# --- Optional: Streamlit -> Backend API base URL ---
# When running Streamlit separately (or deployed), point it to your FastAPI backend.
DOCUMIND_API_BASE_URL=http://localhost:8000

# --- Optional: Uploaded PDF lifecycle ---
# If enabled (1), PDFs are deleted from local disk after a successful indexing.
# Useful for ephemeral filesystems (e.g. Streamlit Cloud).
DOCUMIND_DELETE_UPLOADED_PDFS=0

# Optional: upload/indexing timeout (seconds) for Streamlit -> backend call.
# Helpful for large PDFs or cold starts in hosted environments.
# DOCUMIND_UPLOAD_TIMEOUT_SECONDS=600

# --- Optional: Streamlit security/proxy flags ---
# Local/dev default is secure (true/true).
# In Hugging Face Spaces, start.sh auto-falls back to false/false unless you set
# these explicitly.
# STREAMLIT_ENABLE_CORS=true
# STREAMLIT_ENABLE_XSRF_PROTECTION=true

# --- Optional: Hugging Face Hub download/network settings ---
# Increase timeouts if you see ReadTimeoutError while downloading models.
HF_HUB_CONNECT_TIMEOUT=30
HF_HUB_READ_TIMEOUT=120

# Optional: offline mode if models are already cached
# HF_HUB_OFFLINE=1

# Optional: override reranker model
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
